{
  "tools": [
    {
      "name": "rdev.invites.create",
      "description": "Create an Agent-first remote session invite with a universal connection entry, manifest URL, pinned manifest root, transport plan, and next MCP actions.",
      "safety": "Creates an access path and connection metadata; does not execute on the host.",
      "inputSchema": {
        "additionalProperties": false,
        "properties": {
          "authority_profile": {
            "enum": [
              "standard",
              "max-control"
            ],
            "type": "string"
          },
          "capabilities": {
            "items": {
              "minLength": 1,
              "type": "string"
            },
            "type": "array"
          },
          "gateway_url": {
            "minLength": 1,
            "type": "string"
          },
          "mode": {
            "enum": [
              "attended-temporary",
              "managed",
              "break-glass"
            ],
            "type": "string"
          },
          "network_scope": {
            "enum": [
              "auto",
              "internet",
              "lan",
              "relay",
              "mesh",
              "ssh"
            ],
            "type": "string"
          },
          "once": {
            "type": "boolean"
          },
          "rdev_command": {
            "minLength": 1,
            "type": "string"
          },
          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "require_host_approval": {
            "type": "boolean"
          },
          "transport": {
            "enum": [
              "auto",
              "wss",
              "long-poll",
              "poll"
            ],
            "type": "string"
          },
          "ttl_seconds": {
            "maximum": 86400,
            "minimum": 60,
            "type": "integer"
          }
        },
        "required": [
          "gateway_url",
          "reason"
        ],
        "type": "object"
      }
    },
    {
      "name": "rdev.tickets.create",
