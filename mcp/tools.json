          "reason": {
            "minLength": 1,
            "type": "string"
          },
          "ttl_seconds": {
            "maximum": 86400,
            "minimum": 60,
            "type": "integer"
          }
        },
        "required": [
          "mode",
          "ttl_seconds",
          "reason"
        ],
        "type": "object"
      }
    },
    {
      "name": "rdev.tickets.revoke",
